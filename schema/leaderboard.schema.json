{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Leaderboard",
  "type": "object",
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_runs": {
      "type": "integer",
      "minimum": 0
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "model": { "type": "string" },
          "runs": { "type": "integer" },
          "sfw_overall": { "type": "number" },
          "nsfw_overall": { "type": "number" },
          "combined_overall": { "type": "number" },
          "best_category": { "type": "string" },
          "worst_category": { "type": "string" },
          "most_common_flag": { "type": "string" },
          "run_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["model", "runs", "sfw_overall", "nsfw_overall", "run_ids"]
      }
    }
  },
  "required": ["generated_at", "total_runs", "models"]
}